# Server (default bind is localhost; set 0.0.0.0 only when intentionally exposing)
MCP_HOST=127.0.0.1
MCP_PORT=8787
MCP_TRANSPORT=streamable-http
# MCP_AUTH_MODE=none
# When MCP_AUTH_MODE=bearer, set a strong shared secret (HTTP/SSE only; unused for stdio):
# MCP_BEARER_TOKEN=
# MCP_MAX_REQUEST_BODY_BYTES=

# Search
SEARCH_PROVIDER=ddgs
SEARCH_MAX_RESULTS=5
# Preferred timeouts (seconds). SEARCH_TIMEOUT is a deprecated alias for both.
SEARCH_TIMEOUT_SECONDS=30
FETCH_TIMEOUT_SECONDS=30
# SEARCH_TIMEOUT=30
# SEARCH_RETRY_MAX=1
# SEARCH_RETRY_BACKOFF_SECONDS=0.5

# Optional search filters (provider-dependent)
# SEARCH_SAFE_SEARCH=
# SEARCH_REGION=
# SEARCH_TIME_RANGE=
# SEARCH_ALLOW_UNSUPPORTED_FILTERS=false
# Opt-in fallbacks after SEARCH_PROVIDER (comma-separated allowlist names).
# No fallback on config/auth errors. Example: SEARCH_FALLBACK_PROVIDERS=brave,ddgs
# SEARCH_FALLBACK_PROVIDERS=

# Provider endpoints (P1)
# SEARXNG_BASE_URL=https://searx.example
# SEARXNG_API_KEY=
# BRAVE_BASE_URL=https://api.search.brave.com
# BRAVE_API_KEY=
# TAVILY_BASE_URL=https://api.tavily.com
# TAVILY_API_KEY=
# EXA_BASE_URL=https://api.exa.ai
# EXA_API_KEY=
# Allow http:// provider base_url (local SearXNG). Default false; https required otherwise.
# PROVIDER_ALLOW_HTTP=false

# Fetch / SSRF policy
# FETCH_MAX_BYTES=2097152
# FETCH_MAX_PDF_BYTES=20971520
# FETCH_MAX_REDIRECTS=5
# FETCH_MAX_COMPRESSED_BYTES=2097152
# FETCH_MAX_DECOMPRESSED_BYTES=4194304
# FETCH_ALLOW_HTTP=true
# Empty = any valid port; e.g. 80,443 to restrict
# FETCH_ALLOWED_PORTS=
# PDF_MAX_PAGES=50
# PDF_MAX_CHARS=32000

# Extraction
# PAGE_MAX_CHARS=32000
# HTML_MIN_MAIN_CONTENT_CHARS=200
# HTML_INCLUDE_LINKS=true
# HTML_INCLUDE_IMAGES=false
# HTML_OUTPUT_FORMAT=markdown

# Concurrency / cache (cache behavior is phase 8)
# SEARCH_MAX_CONCURRENCY=8
# FETCH_MAX_CONCURRENCY=16
# PDF_MAX_CONCURRENCY=2
# CACHE_ENABLED=false
# SEARCH_CACHE_TTL_SECONDS=300
# FETCH_CACHE_TTL_SECONDS=600
# CACHE_MAX_ENTRIES=256
# CACHE_MAX_BYTES=33554432

# Logging (queries/URLs off by default)
# LOG_LEVEL=INFO
# LOG_FORMAT=text
# LOG_INCLUDE_QUERIES=false
# LOG_INCLUDE_URLS=false
