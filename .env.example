# Server (default bind is localhost; set 0.0.0.0 only when intentionally exposing)
MCP_HOST=127.0.0.1
MCP_PORT=8787
MCP_TRANSPORT=streamable-http
# MCP_AUTH_MODE=none
# MCP_BEARER_TOKEN=

# Search
SEARCH_PROVIDER=ddgs
SEARCH_MAX_RESULTS=5
# Preferred timeouts (seconds). SEARCH_TIMEOUT is a deprecated alias for both.
SEARCH_TIMEOUT_SECONDS=30
FETCH_TIMEOUT_SECONDS=30
# SEARCH_TIMEOUT=30

# Optional search filters (provider-dependent)
# SEARCH_SAFE_SEARCH=
# SEARCH_REGION=
# SEARCH_TIME_RANGE=
# SEARCH_ALLOW_UNSUPPORTED_FILTERS=false
# Opt-in fallbacks after SEARCH_PROVIDER (comma-separated allowlist names).
# No fallback on config/auth errors. Example: SEARCH_FALLBACK_PROVIDERS=brave,ddgs
# SEARCH_FALLBACK_PROVIDERS=

# Provider endpoints (P1)
# SEARXNG_BASE_URL=https://searx.example
# SEARXNG_API_KEY=
# BRAVE_BASE_URL=https://api.search.brave.com
# BRAVE_API_KEY=
# TAVILY_BASE_URL=https://api.tavily.com
# TAVILY_API_KEY=
# EXA_BASE_URL=https://api.exa.ai
# EXA_API_KEY=
# Allow http:// provider base_url (local SearXNG). Default false; https required otherwise.
# PROVIDER_ALLOW_HTTP=false

# Extraction
# PAGE_MAX_CHARS=32000

# Logging (queries/URLs off by default)
# LOG_LEVEL=INFO
# LOG_INCLUDE_QUERIES=false
# LOG_INCLUDE_URLS=false
